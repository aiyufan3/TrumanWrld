# Model provider
OPENAI_BASE_URL=https://api.minimaxi.com/v1
OPENAI_API_KEY=your_minimax_api_key_here
MODEL_PRIMARY=MiniMax-M2.7
MODEL_FAST=MiniMax-M2.7-highspeed
MODEL_REASONING=MiniMax-M2.7

# App
NODE_ENV=development
APP_PORT=3000
LOG_LEVEL=info
HARNESS_RUNTIME_PATH=./runtime/harness
HARNESS_MAX_DRAFT_RETRIES=3
SECURITY_MODE=strict
BLOCK_SENSITIVE_INGESTION=true
BLOCK_MODEL_PROMPTS_WITH_SECRETS=true
BLOCK_PUBLISH_PAYLOADS_WITH_SECRETS=true
ALLOW_BROWSER_LOGIN_AUTOMATION=false
ALLOW_PASSWORD_BASED_AUTOMATION=false
AUTH_SERVER_HOST=127.0.0.1
AUTH_SERVER_PORT=8788
AUTH_BASE_URL=http://127.0.0.1:8788
OAUTH_TOKEN_STORE_PATH=./runtime/secure/oauth-tokens.enc
OAUTH_TOKEN_ENCRYPTION_KEY=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_kol_os
REDIS_URL=redis://localhost:6379

# Memory
HERMES_MEMORY_BACKEND=file
HERMES_MEMORY_PATH=./data/memory

# X (Twitter)
# App-Only & OAuth 1.0a Keys
X_API_KEY=your_consumer_key_here
X_API_KEY_SECRET=your_consumer_secret_key_here
X_BEARER_TOKEN=your_bearer_token_here
X_ACCESS_TOKEN=the_access_token_you_just_regenerated
X_ACCESS_TOKEN_SECRET=the_access_token_secret_you_just_regenerated

# OAuth 2.0 Keys
X_CLIENT_ID=your_oauth2_client_id_here
X_CLIENT_SECRET=your_oauth2_client_secret_here
X_OAUTH_SCOPES=tweet.read tweet.write users.read offline.access

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_OAUTH_SCOPES=threads_basic,threads_content_publish
THREADS_ACCESS_TOKEN=

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=

# Browser / automation
BROWSERBASE_API_KEY=
PLAYWRIGHT_STORAGE_STATE_PATH=./secrets/playwright-storage-state.json

# Safety
PUBLISH_MODE=approval_only
ALLOW_REAL_POSTS=false
ALLOW_BROWSER_AUTOMATION=false
ALLOW_EXTERNAL_SIDE_EFFECTS=false
PUBLISH_MAX_ATTEMPTS=3
PUBLISH_RETRY_BACKOFF_MS=1200

# Hermes Daemon
HERMES_INTERVAL_MIN_HOURS=4
HERMES_INTERVAL_MAX_HOURS=6
HERMES_AUTO_APPROVE=true

# Engagement Agent
ENGAGEMENT_ENABLED=true
ENGAGEMENT_MAX_PER_CYCLE=5
