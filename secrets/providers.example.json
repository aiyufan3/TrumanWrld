{
  "model": {
    "provider": "minimax-openai-compatible",
    "baseUrlEnv": "OPENAI_BASE_URL",
    "apiKeyEnv": "OPENAI_API_KEY",
    "primaryModelEnv": "MODEL_PRIMARY",
    "fastModelEnv": "MODEL_FAST",
    "reasoningModelEnv": "MODEL_REASONING"
  },
  "x": {
    "apiKeyEnv": "X_API_KEY",
    "apiSecretEnv": "X_API_KEY_SECRET",
    "bearerTokenEnv": "X_BEARER_TOKEN",
    "accessTokenEnv": "X_ACCESS_TOKEN",
    "accessTokenSecretEnv": "X_ACCESS_TOKEN_SECRET",
    "oauth2ClientIdEnv": "X_CLIENT_ID",
    "oauth2ClientSecretEnv": "X_CLIENT_SECRET",
    "scopeEnv": "X_OAUTH_SCOPES",
    "tokenStoreEnv": "OAUTH_TOKEN_STORE_PATH"
  },
  "threads": {
    "appIdEnv": "THREADS_APP_ID",
    "appSecretEnv": "THREADS_APP_SECRET",
    "scopeEnv": "THREADS_OAUTH_SCOPES",
    "tokenStoreEnv": "OAUTH_TOKEN_STORE_PATH"
  },
  "notifications": {
    "telegramBotTokenEnv": "TELEGRAM_BOT_TOKEN",
    "telegramChatIdEnv": "TELEGRAM_CHAT_ID",
    "slackWebhookEnv": "SLACK_WEBHOOK_URL"
  }
}
